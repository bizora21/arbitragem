# Base chain RPC (default: public, consider Alchemy/Infura for production)
BASE_RPC_URL=https://mainnet.base.org

# Private key of the wallet that owns the deployed contract (WITHOUT 0x prefix OR with)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Address of FlashLoanArb.sol after deploy (fill after running npm run deploy)
CONTRACT_ADDRESS=0x...

# BaseScan API key for contract verification (get at https://basescan.org/myapikey)
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# Bot thresholds
MIN_NET_EDGE_BP=8        # minimum net edge in basis points (8 = 0.08%)
MIN_PROFIT_USD=1.00      # minimum estimated profit in USD

# Flash loan amount in USD (the scanner uses $10,000 by default)
FLASH_LOAN_AMOUNT=10000

# Scan interval in milliseconds
SCAN_INTERVAL_MS=15000
